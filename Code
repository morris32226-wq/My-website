3. Replace the <div class="coin-photo no-image"> block with:
<div class="coin-photo">
<img src="YOUR_IMAGE_FILENAME.jpg" alt="Coin Name">
</div>
*/

@media (max-width: 768px) {
header { padding: 60px 20px 40px; }
main { padding: 0 16px 80px; }
nav { padding: 0 16px; }
.stats-bar { gap: 30px; padding: 20px; }
.coin-grid { grid-template-columns: 1fr; gap: 2px; }
nav a { padding: 14px 12px; font-size: 0.62rem; }
}
</style>

