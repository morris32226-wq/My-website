<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>The Mercer Collection — Ancient Coins</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Cinzel:wght@400;500;600&family=EB+Garamond:ital,wght@0,400;1,400&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0a0906;
    --bg2: #111008;
    --bg3: #1a1710;
    --gold: #c9a84c;
    --gold-dim: #8a6e2f;
    --gold-bright: #e8c96a;
    --silver: #b8b4a8;
    --silver-dim: #6e6b62;
    --text: #d4cfc4;
    --text-dim: #8a857a;
    --border: #2a2620;
    --border-gold: #3a3020;
    --accent: #c9a84c22;
  }

- { margin: 0; padding: 0; box-sizing: border-box; }

html { scroll-behavior: smooth; }

body {
background: var(–bg);
color: var(–text);
font-family: ‘EB Garamond’, serif;
font-size: 17px;
line-height: 1.7;
cursor: default;
}

/* Grain overlay */
body::before {
content: ‘’;
position: fixed;
inset: 0;
background-image: url(“data:image/svg+xml,%3Csvg viewBox=‘0 0 256 256’ xmlns=‘http://www.w3.org/2000/svg’%3E%3Cfilter id=‘noise’%3E%3CfeTurbulence type=‘fractalNoise’ baseFrequency=‘0.9’ numOctaves=‘4’ stitchTiles=‘stitch’/%3E%3C/filter%3E%3Crect width=‘100%25’ height=‘100%25’ filter=‘url(%23noise)’ opacity=‘0.04’/%3E%3C/svg%3E”);
pointer-events: none;
z-index: 1000;
opacity: 0.4;
}

/* Header */
header {
position: relative;
text-align: center;
padding: 80px 40px 60px;
border-bottom: 1px solid var(–border-gold);
background: linear-gradient(180deg, #0f0c07 0%, var(–bg) 100%);
overflow: hidden;
}

header::before {
content: ‘’;
position: absolute;
top: 0; left: 50%; transform: translateX(-50%);
width: 600px; height: 1px;
background: linear-gradient(90deg, transparent, var(–gold-dim), transparent);
}

header::after {
content: ‘’;
position: absolute;
bottom: -1px; left: 50%; transform: translateX(-50%);
width: 300px; height: 1px;
background: linear-gradient(90deg, transparent, var(–gold), transparent);
}

.collection-label {
font-family: ‘Cinzel’, serif;
font-size: 10px;
letter-spacing: 6px;
color: var(–gold-dim);
text-transform: uppercase;
margin-bottom: 20px;
opacity: 0;
animation: fadeUp 1s ease 0.2s forwards;
}

h1 {
font-family: ‘Cinzel’, serif;
font-size: clamp(2.2rem, 5vw, 3.8rem);
font-weight: 400;
color: var(–gold);
letter-spacing: 3px;
line-height: 1.15;
opacity: 0;
animation: fadeUp 1s ease 0.4s forwards;
}

.header-sub {
font-family: ‘Cormorant Garamond’, serif;
font-style: italic;
font-size: 1.15rem;
color: var(–silver-dim);
margin-top: 14px;
letter-spacing: 1px;
opacity: 0;
animation: fadeUp 1s ease 0.6s forwards;
}

.header-rule {
display: flex;
align-items: center;
justify-content: center;
gap: 16px;
margin: 30px auto 0;
width: fit-content;
opacity: 0;
animation: fadeUp 1s ease 0.8s forwards;
}

.header-rule span {
width: 60px; height: 1px;
background: linear-gradient(90deg, transparent, var(–gold-dim));
}

.header-rule span:last-child {
background: linear-gradient(270deg, transparent, var(–gold-dim));
}

.header-rule .diamond {
width: 6px; height: 6px;
background: var(–gold);
transform: rotate(45deg);
width: auto; height: auto;
font-size: 8px;
color: var(–gold);
}

/* Stats bar */
.stats-bar {
display: flex;
justify-content: center;
gap: 60px;
padding: 28px 40px;
border-bottom: 1px solid var(–border);
background: var(–bg2);
opacity: 0;
animation: fadeUp 1s ease 1s forwards;
}

.stat {
text-align: center;
}

.stat-num {
font-family: ‘Cinzel’, serif;
font-size: 1.4rem;
color: var(–gold);
display: block;
}

.stat-label {
font-size: 0.75rem;
color: var(–text-dim);
letter-spacing: 2px;
text-transform: uppercase;
}

/* Nav */
nav {
position: sticky;
top: 0;
z-index: 100;
background: rgba(10, 9, 6, 0.95);
backdrop-filter: blur(10px);
border-bottom: 1px solid var(–border-gold);
padding: 0 40px;
display: flex;
gap: 0;
overflow-x: auto;
scrollbar-width: none;
}

nav::-webkit-scrollbar { display: none; }

nav a {
font-family: ‘Cinzel’, serif;
font-size: 0.7rem;
letter-spacing: 2.5px;
text-transform: uppercase;
color: var(–text-dim);
text-decoration: none;
padding: 18px 20px;
white-space: nowrap;
border-bottom: 1px solid transparent;
transition: color 0.3s, border-color 0.3s;
margin-bottom: -1px;
}

nav a:hover {
color: var(–gold);
border-bottom-color: var(–gold);
}

/* Main layout */
main {
max-width: 1400px;
margin: 0 auto;
padding: 0 40px 100px;
}

/* Section */
.section {
margin-top: 80px;
opacity: 0;
transform: translateY(30px);
animation: fadeUp 0.8s ease forwards;
}

.section:nth-child(1) { animation-delay: 0.1s; }
.section:nth-child(2) { animation-delay: 0.2s; }
.section:nth-child(3) { animation-delay: 0.3s; }
.section:nth-child(4) { animation-delay: 0.4s; }
.section:nth-child(5) { animation-delay: 0.5s; }
.section:nth-child(6) { animation-delay: 0.6s; }
.section:nth-child(7) { animation-delay: 0.7s; }
.section:nth-child(8) { animation-delay: 0.8s; }

.section-header {
display: flex;
align-items: center;
gap: 20px;
margin-bottom: 40px;
padding-bottom: 16px;
border-bottom: 1px solid var(–border-gold);
}

.section-title {
font-family: ‘Cinzel’, serif;
font-size: 0.75rem;
letter-spacing: 5px;
text-transform: uppercase;
color: var(–gold);
}

.section-line {
flex: 1;
height: 1px;
background: linear-gradient(90deg, var(–border-gold), transparent);
}

.section-count {
font-family: ‘Cinzel’, serif;
font-size: 0.65rem;
color: var(–text-dim);
letter-spacing: 2px;
}

/* Coin grid */
.coin-grid {
display: grid;
grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
gap: 2px;
}

/* Coin card */
.coin-card {
background: var(–bg2);
border: 1px solid var(–border);
position: relative;
transition: border-color 0.4s, transform 0.4s;
cursor: pointer;
overflow: hidden;
}

.coin-card::before {
content: ‘’;
position: absolute;
inset: 0;
background: linear-gradient(135deg, var(–accent) 0%, transparent 60%);
opacity: 0;
transition: opacity 0.4s;
pointer-events: none;
}

.coin-card:hover {
border-color: var(–gold-dim);
transform: translateY(-2px);
z-index: 2;
}

.coin-card:hover::before {
opacity: 1;
}

/* Photo area */
.coin-photo {
width: 100%;
aspect-ratio: 16/9;
background: #0d0b08;
display: flex;
align-items: center;
justify-content: center;
position: relative;
overflow: hidden;
border-bottom: 1px solid var(–border);
}

.coin-photo img {
width: 100%;
height: 100%;
object-fit: cover;
transition: transform 0.6s ease;
filter: sepia(10%) contrast(1.05);
}

.coin-card:hover .coin-photo img {
transform: scale(1.03);
}

.coin-photo.no-image {
flex-direction: column;
gap: 10px;
}

.coin-photo.no-image .photo-icon {
font-size: 2rem;
opacity: 0.15;
}

.coin-photo.no-image .photo-label {
font-family: ‘Cinzel’, serif;
font-size: 0.6rem;
letter-spacing: 3px;
color: var(–text-dim);
opacity: 0.4;
text-transform: uppercase;
}

/* Card body */
.coin-body {
padding: 24px 26px 26px;
}

.coin-name {
font-family: ‘Cormorant Garamond’, serif;
font-size: 1.15rem;
font-weight: 600;
color: var(–text);
line-height: 1.3;
margin-bottom: 4px;
}

.coin-date {
font-family: ‘Cinzel’, serif;
font-size: 0.65rem;
letter-spacing: 2px;
color: var(–gold-dim);
text-transform: uppercase;
margin-bottom: 14px;
}

.coin-attribution {
font-size: 0.82rem;
color: var(–text-dim);
font-style: italic;
margin-bottom: 16px;
line-height: 1.5;
padding-bottom: 16px;
border-bottom: 1px solid var(–border);
}

.coin-meta {
display: grid;
grid-template-columns: 1fr 1fr;
gap: 10px 20px;
margin-bottom: 16px;
}

.meta-item {}

.meta-key {
font-family: ‘Cinzel’, serif;
font-size: 0.58rem;
letter-spacing: 2px;
color: var(–gold-dim);
text-transform: uppercase;
display: block;
margin-bottom: 2px;
}

.meta-val {
font-size: 0.85rem;
color: var(–silver);
}

.coin-notes {
font-size: 0.88rem;
color: var(–text-dim);
font-style: italic;
line-height: 1.6;
padding-top: 14px;
border-top: 1px solid var(–border);
}

.coin-notes::before {
content: ‘”’;
color: var(–gold-dim);
font-size: 1.2rem;
font-family: ‘Cormorant Garamond’, serif;
margin-right: 2px;
}

.coin-notes::after {
content: ‘”’;
color: var(–gold-dim);
font-size: 1.2rem;
font-family: ‘Cormorant Garamond’, serif;
margin-left: 2px;
}

/* Grade badge */
.grade-badge {
display: inline-block;
font-family: ‘Cinzel’, serif;
font-size: 0.6rem;
letter-spacing: 2px;
padding: 3px 8px;
border: 1px solid var(–gold-dim);
color: var(–gold);
text-transform: uppercase;
margin-bottom: 14px;
}

/* Footer */
footer {
text-align: center;
padding: 60px 40px;
border-top: 1px solid var(–border-gold);
background: var(–bg2);
}

.footer-logo {
font-family: ‘Cinzel’, serif;
font-size: 1rem;
letter-spacing: 4px;
color: var(–gold-dim);
margin-bottom: 10px;
}

.footer-sub {
font-size: 0.8rem;
color: var(–text-dim);
font-style: italic;
}

/* Animations */
@keyframes fadeUp {
from { opacity: 0; transform: translateY(20px); }
to { opacity: 1; transform: translateY(0); }
}

/* HOW TO ADD PHOTOS - hidden comment guide */
/*
TO ADD A PHOTO TO A COIN:
1. Place your image file (JPG or PNG) in the same folder as this HTML file
